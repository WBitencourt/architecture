// --- Enums (restringe effect no banco)
enum EffectType {
  allow
  deny
}

// 1. Usuário — tabela: users
model User {
  id    String @id @default(uuid())
  name  String
  email String @unique

  // N:N com Role via user_roles (um usuário pode ter várias roles; uma role pode estar em vários usuários)
  roles UserRole[]

  // 1:N — permissões exclusivas deste usuário (exceções/overrides em cima das permissões das roles)
  customPermissions UserPermission[]

  @@map("users")
}

// 2. Cargo / Papel (ex.: RH, Suporte) — tabela: roles
model Role {
  id   String @id @default(uuid())
  name String @unique // ex: "RH", "SUPORTE"

  // N:N com User via user_roles
  users UserRole[]

  // 1:N — políticas ABAC padrão desta role (effect, action, subject, fields, conditions)
  permissions RolePermission[]

  @@map("roles")
}

// Tabela pivot User ↔ Role — tabela: user_roles (evita nome implícito _RoleToUser)
model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

// 3. Política de permissão da Role (um “statement” ABAC por linha) — tabela: role_permissions
model RolePermission {
  id         String      @id @default(uuid())
  effect     EffectType  @default(allow)   // allow | deny
  action     String      // verbo: read, create, update, delete, manage
  subject    String      // recurso: user, folha_pagamento, chamado
  fields     Json?       // acesso fino: ["name", "email"] ou null = todos os campos
  conditions Json?       // escopo: { "departamento": "TI" }

  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId String

  @@map("role_permissions")
}

// 4. Política de permissão do Usuário (exceção/override por usuário) — tabela: user_permissions
model UserPermission {
  id         String      @id @default(uuid())
  effect     EffectType  @default(allow)
  action     String
  subject    String
  fields     Json?
  conditions Json?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@map("user_permissions")
}
